{
  "name": "gdb-mcp",
  "version": "0.2.0",
  "description": "Multi-session GDB and gdbserver debugging through MCP.",
  "author": {
    "name": "BeaCox",
    "email": "root@beacox.space"
  },
  "homepage": "https://github.com/BeaCox/gdb-mcp",
