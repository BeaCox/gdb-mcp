  "license": "MIT",
  "keywords": [
    "gdb",
    "debugger",
    "gdbserver",
    "mcp"
  ],
  "mcpServers": {
    "gdb": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "${CLAUDE_PLUGIN_ROOT}",
        "gdb-mcp"
      ]
    }
  }
}
